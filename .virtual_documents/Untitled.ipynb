"""
Data Collection Script
======================
Run this script ONCE on your local machine to fetch all raw data.
Outputs are saved to the /data folder and committed to GitHub.
The main analysis notebook reads from those CSV files directly.

Requirements:
    pip install requests pandas entsoe-py

NOTE: If running inside Jupyter, replace DATA_DIR with:
    DATA_DIR = Path("../data")
"""

import requests
import pandas as pd
from entsoe import EntsoePandasClient
from pathlib import Path

# ── Paths ──────────────────────────────────────────────────────────────────────
# Use __file__ when running as a script; change to Path("../data") in Jupyter
DATA_DIR = Path("data").parent / "data"
DATA_DIR.mkdir(exist_ok=True)

# ── Time range ─────────────────────────────────────────────────────────────────
START = pd.Timestamp("2020-01-01", tz="Europe/Sofia")
END   = pd.Timestamp("2024-12-31", tz="Europe/Sofia")


# ══════════════════════════════════════════════════════════════════════════════
# SOURCE 1: ENTSO-E  —  Day-Ahead Prices + Actual Load (Bulgaria)
# ══════════════════════════════════════════════════════════════════════════════

def fetch_entsoe(api_token: str) -> None:
    """
    Fetches hourly day-ahead electricity prices (€/MWh) and
    actual load (MW) for Bulgaria from the ENTSO-E Transparency Platform.

    API docs: https://transparency.entsoe.eu/content/static_content/Static%20content/web%20api/Guide.html
    Area code: BG (Bulgaria)
    """
    print("Connecting to ENTSO-E API...")
    client = EntsoePandasClient(api_key=api_token)

    # Day-ahead prices — €/MWh, hourly resolution
    print("Fetching day-ahead prices (BG)...")
    prices = client.query_day_ahead_prices("BG", start=START, end=END)
    prices = prices.rename("price_eur_mwh")
    prices.index.name = "time"
    prices_df = prices.reset_index()
    prices_df.to_csv(DATA_DIR / "entsoe_prices.csv", index=False)
    print(f"  Saved entsoe_prices.csv — {len(prices_df):,} rows")

    # Actual load — MW, hourly resolution
    print("Fetching actual load (BG)...")
    load = client.query_load("BG", start=START, end=END)
    load.index.name = "time"
    load_df = load.reset_index()
    load_df.columns = ["time", "load_mw"]
    load_df.to_csv(DATA_DIR / "entsoe_load.csv", index=False)
    print(f"  Saved entsoe_load.csv — {len(load_df):,} rows")


# ══════════════════════════════════════════════════════════════════════════════
# SOURCE 2: Open-Meteo  —  Hourly Temperature for Sofia, Bulgaria
# ══════════════════════════════════════════════════════════════════════════════

def fetch_weather() -> None:
    """
    Fetches hourly weather variables for Sofia (42.6977°N, 23.3219°E)
    from the Open-Meteo Historical Weather API.

    Variables fetched:
        - temperature_2m     : Air temperature at 2m height (°C)
        - precipitation      : Total precipitation (rain + snow, mm)
        - windspeed_10m      : Wind speed at 10m height (km/h)
        - cloudcover         : Total cloud cover (%)
        - snowfall           : Snowfall (cm water equivalent)

    Why these variables?
        - Temperature  → heating/cooling demand, strongest price driver
        - Precipitation → affects hydro reservoir levels (less rain = less hydro = higher prices)
        - Wind speed   → wind generation suppresses wholesale prices
        - Cloud cover  → proxy for solar generation potential
        - Snowfall     → heating demand spike + hydro storage as snowpack

    No API key required.
    Docs: https://open-meteo.com/en/docs/historical-weather-api
    """
    print("Fetching weather data from Open-Meteo...")

    url = "https://archive-api.open-meteo.com/v1/archive"
    params = {
        "latitude": 42.6977,
        "longitude": 23.3219,
        "start_date": "2020-01-01",
        "end_date": "2024-12-31",
        "hourly": "temperature_2m,precipitation,windspeed_10m,cloudcover,snowfall",
        "timezone": "Europe/Sofia",
    }

    response = requests.get(url, params=params, timeout=30)
    response.raise_for_status()
    data = response.json()

    df = pd.DataFrame({
        "time":          data["hourly"]["time"],
        "temperature_c": data["hourly"]["temperature_2m"],
        "precipitation_mm": data["hourly"]["precipitation"],
        "windspeed_kmh": data["hourly"]["windspeed_10m"],
        "cloudcover_pct": data["hourly"]["cloudcover"],
        "snowfall_cm":   data["hourly"]["snowfall"],
    })
    df["time"] = pd.to_datetime(df["time"])
    df.to_csv(DATA_DIR / "weather_sofia.csv", index=False)
    print(f"  Saved weather_sofia.csv — {len(df):,} rows")
    print(f"  Columns: {list(df.columns)}")


# ══════════════════════════════════════════════════════════════════════════════
# MAIN
# ══════════════════════════════════════════════════════════════════════════════

if __name__ == "__main__":
    # ── Weather (no token needed) ──────────────────────────────────────────
    fetch_weather()

    # ── ENTSO-E (paste your API token here) ───────────────────────────────
    ENTSOE_TOKEN = "PASTE_YOUR_TOKEN_HERE"

    if ENTSOE_TOKEN == "PASTE_YOUR_TOKEN_HERE":
        print("\nSkipping ENTSO-E fetch — no API token provided.")
        print("Paste your token into ENTSOE_TOKEN and re-run.")
    else:
        fetch_entsoe(ENTSOE_TOKEN)

    print("\nDone. All CSVs saved to /data.")


get_ipython().getoutput("pip install entsoe-py")



